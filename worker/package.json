{
  "name": "tbes-redirect-auth",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "npm run check:syntax && npm test",
    "check:syntax": "node --check src/index.js && node --check src/entry.js && node --check src/short-redirects.js",
    "check:deploy": "wrangler deploy --dry-run --outdir .wrangler/dry-run",
    "test": "node --test test/*.test.mjs",
    "types": "wrangler types --include-runtime false",
    "types:check": "wrangler types --include-runtime false --check",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy"
  },
  "devDependencies": {
    "wrangler": "^4.111.0"
  },
  "engines": {
    "node": ">=22"
  }
}
